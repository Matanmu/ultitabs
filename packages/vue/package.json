    "@ultitabs/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "license": "MIT",
  "keywords": ["tabs", "vue", "vue3", "ui", "aria", "accessible", "animated"],
  "repository": {
    "type": "git",
